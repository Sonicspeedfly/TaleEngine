# Скопируйте этот файл в .env и заполните нужные значения.
#   cp .env.example .env

# ===== Сервер =====
APP_NAME=AiChat SSF
HOST=0.0.0.0
PORT=8000
DEBUG=false
# Через запятую — какие origin'ы фронтенда пускать (CORS).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== База данных (ОБЩАЯ для backend и Telegram-бота) =====
DATABASE_URL=sqlite+aiosqlite:///./data/aichat.db

# ===== LLM / LiteLLM =====
# DEFAULT_MODEL — имя модели КАК ОНО НАЗВАНО в вашем LiteLLM-прокси.
DEFAULT_MODEL=gpt-4o
REQUEST_TIMEOUT=120
# Минимальный таймаут для БОЛЬШИХ мультимодальных запросов (inline-видео/аудио > 8 МБ):
# заливка в прокси/Vertex и обработка медиа занимают дольше обычного текста.
# Реальный таймаут ещё и растёт с размером файла (~10 с/МБ, потолок 30 минут).
LARGE_REQUEST_TIMEOUT=900
# Окно контекста («память» диалога, ~токенов истории на ход). По умолчанию —
# максимум Gemini (~1 млн). Переопределяется в UI (Генерация -> «Окно контекста»).
# Больше = помнит дальше, но дороже/медленнее (свыше ~200 тыс. — дороже тариф).
CONTEXT_TOKEN_BUDGET=1000000
# Лимит ФАЙЛОВ истории (МБ на ход): прежние вложения пересылаются модели заново.
# 0 = БЕЗ лимита (полная память по файлам). Переопределяется в UI
# (Генерация -> «Файлы в памяти диалога»).
HISTORY_FILES_MB=0

# ===== LiteLLM Proxy (основной путь) =====
# У вас прокси уже запущен на :4000 — всё уходит туда, ключи провайдеров живут в прокси.
# Эти значения можно менять прямо в интерфейсе (вкладка «Подключение»).
LITELLM_USE_PROXY=true
LITELLM_BASE_URL=http://localhost:4000
# master key прокси (если включён), формата sk-...
LITELLM_API_KEY=

# Дефолтные параметры генерации (переопределяются на уровне персонажа/UI)
DEFAULT_TEMPERATURE=0.9
DEFAULT_TOP_P=0.95
DEFAULT_TOP_K=40
DEFAULT_MAX_TOKENS=1024
DEFAULT_REPETITION_PENALTY=1.1

# ===== Ключи провайдеров (заполните те, что используете) =====
# LiteLLM читает их из окружения автоматически по имени модели.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Для Vertex AI: проект GCP и регион (плюс GOOGLE_APPLICATION_CREDENTIALS при необходимости).
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# С каким персонажем начинать чат в Telegram, если у пользователя ещё нет сессии
# (id персонажа из веб-интерфейса). Оставьте строку ЗАКОММЕНТИРОВАННОЙ, если не нужно
# (пустое значение тоже допустимо — трактуется как «не задано»).
# TELEGRAM_DEFAULT_CHARACTER_ID=1
